{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "CloudWasteScanner",
  "version" : "2.9.18",
  "identifier": "com.cloud-waste-scanner.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "security": {
      "csp": null
    },
    "windows": [
      {
        "fullscreen": false,
        "maximized": true,
        "minWidth": 1280,
        "minHeight": 800,
        "resizable": true,
        "title": "Cloud Waste Scanner Community",
        "width": 1200,
        "height": 800
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": [
      "dmg",
      "nsis",
      "deb",
      "appimage",
      "rpm"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico",
      "icons/icon.icns"
    ],
    "resources": [
      "WebView2Loader.dll"
    ],
    "windows": {
      "nsis": {
        "template": "windows/nsis/installer.nsi.template"
      }
    }
  }
}
